---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Psychosassquatch — music that will make you groove',
  description = 'Psychosassquatch is the music project of Rene Ramirez. Electronic, lo-fi, alternative, hip-hop, indie. Loud feelings. Loud fur.',
} = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-sass-bg text-sass-ink">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0a0a08" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content="/og.png" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" href="/logo/PsychoSassquatch.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Space+Grotesk:wght@500;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <ViewTransitions />

    <!-- ── Google Analytics (GA4) ──────────────────────────────────────── -->
    <!-- Paste your GA4 Measurement ID below (looks like 'G-XXXXXXXXXX'),  -->
    <!-- and the snippet auto-fires page_view events on every SPA route   -->
    <!-- change via astro:page-load. While GA_ID is empty, the snippet    -->
    <!-- is a no-op — nothing gets sent.                                    -->
    <script is:inline>
      window.__PSY_GA_ID = 'G-KMZV3L4LCF';
    </script>
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-KMZV3L4LCF"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      window.gtag = gtag;
      gtag('js', new Date());
      if (window.__PSY_GA_ID) {
        gtag('config', window.__PSY_GA_ID, { send_page_view: false });
        gtag('event', 'page_view', { page_path: location.pathname + location.search });
      }
      // Fire page_view on every SPA transition (Astro ClientRouter / ViewTransitions)
      document.addEventListener('astro:page-load', () => {
        if (window.__PSY_GA_ID) {
          gtag('event', 'page_view', {
            page_path: location.pathname + location.search,
            page_title: document.title,
          });
        }
      });
    </script>
  </head>
  <body class="grain flex min-h-dvh flex-col">
    <slot />

    <!-- ── Persistent audio element. Survives SPA navigation so music keeps playing across pages. -->
    <audio
      id="psy-audio"
      preload="metadata"
      crossorigin="anonymous"
      transition:persist="psy-audio"
    ></audio>
  </body>
</html>
