---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const sections = [
  {
    href: '/music',
    eyebrow: '01',
    title: 'Music',
    note: 'Releases, B-sides, the stuff that escaped the basement.',
  },
  {
    href: '/sessions',
    eyebrow: '02',
    title: 'Sessions',
    note: 'Click things. Make noise. Sasquatch jams with you in the browser.',
  },
  {
    href: '/lore',
    eyebrow: '03',
    title: 'Lore',
    note: 'Bio, press kit, origin story (mostly true, occasionally feral).',
  },
  {
    href: '/merch',
    eyebrow: '04',
    title: 'Merch',
    note: 'Wear the fur. Tees, stickers, contraband.',
  },
  {
    href: '/dispatches',
    eyebrow: '05',
    title: 'Dispatches',
    note: '3am thoughts, field notes, half-finished beats.',
  },
];
---

<Base>
  <Nav />

  <main class="relative">
    <!-- HERO -->
    <section class="relative flex min-h-dvh items-center px-5 pt-28 md:px-10">
      <!-- ambient mascot glow -->
      <div aria-hidden="true" class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
        <div class="absolute -left-32 top-1/3 h-[36rem] w-[36rem] rounded-full bg-sass-sauce/20 blur-[160px]"></div>
        <div class="absolute -right-24 bottom-0 h-[28rem] w-[28rem] rounded-full bg-sass-glow/10 blur-[140px]"></div>
      </div>

      <div class="mx-auto w-full max-w-6xl">
        <p class="font-mono text-xs uppercase tracking-[0.35em] text-sass-ink/60">
          Rene Ramirez presents
        </p>

        <h1 class="mt-4 font-display text-[clamp(3.5rem,12vw,11rem)] font-bold leading-[0.85] tracking-tight">
          Psycho<span class="text-sass-sauce">sass</span>quatch<span class="text-sass-sauce">.</span>
        </h1>

        <p class="mt-6 max-w-xl text-lg text-sass-ink/80 md:text-xl">
          Electronic. Lo-fi. Alternative. Hip-hop. Indie.
          <span class="block text-sass-ink/55">It's whatever the woods told me to make this week.</span>
        </p>

        <div class="mt-10 flex flex-wrap gap-3">
          <a
            href="/music"
            class="inline-flex items-center gap-2 rounded-full bg-sass-sauce px-5 py-3 font-mono text-xs uppercase tracking-widest text-sass-bg transition-transform hover:-translate-y-0.5"
          >
            ▶ Press play
          </a>
          <a
            href="/sessions"
            class="inline-flex items-center gap-2 rounded-full border border-sass-ink/20 px-5 py-3 font-mono text-xs uppercase tracking-widest text-sass-ink/80 hover:border-sass-ink/60 hover:text-sass-ink"
          >
            ✱ Jam in browser
          </a>
        </div>

        <p class="mt-12 max-w-md font-mono text-[11px] uppercase tracking-widest text-sass-ink/40">
          Tip: scroll. The sasquatch is shy but he's down there.
        </p>
      </div>
    </section>

    <!-- COMPARTMENTALIZED NAV GRID -->
    <section class="relative px-5 py-20 md:px-10 md:py-32">
      <div class="mx-auto max-w-6xl">
        <p class="font-mono text-xs uppercase tracking-[0.35em] text-sass-ink/50">
          [pick your portal]
        </p>
        <h2 class="mt-3 font-display text-4xl md:text-6xl">
          Wander the woods.
        </h2>

        <ul class="mt-12 grid gap-px overflow-hidden rounded-3xl border border-sass-ink/10 bg-sass-ink/5 md:grid-cols-2">
          {sections.map((s) => (
            <li class="bg-sass-bg">
              <a
                href={s.href}
                class="group flex h-full flex-col justify-between gap-12 p-8 transition-colors hover:bg-sass-ink/[0.03] md:p-10"
              >
                <div class="flex items-start justify-between">
                  <span class="font-mono text-xs uppercase tracking-widest text-sass-ink/40">
                    {s.eyebrow}
                  </span>
                  <span class="font-mono text-xs text-sass-ink/40 transition-transform group-hover:translate-x-1">
                    →
                  </span>
                </div>
                <div>
                  <h3 class="font-display text-3xl md:text-5xl">
                    <span class="bg-gradient-to-r from-sass-ink to-sass-ink bg-[length:0%_1px] bg-bottom bg-no-repeat transition-all duration-300 group-hover:bg-[length:100%_1px]">
                      {s.title}
                    </span>
                  </h3>
                  <p class="mt-3 max-w-md text-sm text-sass-ink/60">{s.note}</p>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- INTERLUDE / SHOUT -->
    <section class="relative overflow-hidden px-5 py-24 md:px-10">
      <div class="mx-auto max-w-6xl">
        <p class="font-display text-stroke text-[clamp(3rem,10vw,9rem)] font-bold leading-none">
          GROOVE GROOVE GROOVE GROOVE
        </p>
        <p class="mt-6 max-w-lg text-sass-ink/60">
          Some of this site is finished. Some of it is duct-taped. All of it
          is on purpose. If something breaks, that's lore now.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Base>
