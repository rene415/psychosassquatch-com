---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Merch — Psychosassquatch" description="Wear the fur. Tees, stickers, contraband.">
  <Nav />

  <main class="px-5 pt-32 md:px-10">
    <section class="mx-auto max-w-6xl">
      <p class="font-mono text-xs uppercase tracking-[0.35em] text-sass-ink/50">04 — Merch</p>
      <h1 class="mt-3 font-display text-5xl md:text-7xl">Wear the fur.</h1>
      <p class="mt-6 max-w-xl text-sass-ink/70">
        Storefront goes here — could be a Shopify/Snipcart embed, could be Big Cartel,
        could be Rene-just-DMs-you. TBD. For now: vaporware tees.
      </p>

      <div class="mt-12 grid gap-px overflow-hidden rounded-3xl border border-sass-ink/10 bg-sass-ink/5 md:grid-cols-3">
        {['Nugget Tee', 'Forest Hoodie', 'Sticker Pack'].map((n, i) => (
          <article class="bg-sass-bg p-8">
            <div class="aspect-square rounded-2xl bg-sass-fur/30"></div>
            <h2 class="mt-4 font-display text-xl">{n}</h2>
            <p class="text-xs text-sass-ink/50">$— · sold by the forest</p>
            <button class="mt-4 rounded-full border border-sass-ink/20 px-4 py-2 font-mono text-[10px] uppercase tracking-widest text-sass-ink/60" disabled>
              Notify me
            </button>
          </article>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Base>
