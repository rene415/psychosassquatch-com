---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import MusicCarousel from '../components/MusicCarousel.astro';
---

<Base
  title="Music — Psychosassquatch"
  description="Releases, B-sides, and stuff that escaped the basement."
>
  <Nav />

  <main class="px-5 pt-32 md:px-10">
    <section class="mx-auto max-w-6xl">
      <p class="font-mono text-xs uppercase tracking-[0.35em] text-sass-ink/50">01 — Music</p>
      <h1 class="mt-3 font-display text-5xl md:text-7xl">Press play, lose track of time.</h1>
      <p class="mt-6 max-w-xl text-sass-ink/70">
        Every release, newest first. Click a cover to load the Spotify player right in the card.
        Want full tracks? Sign into Spotify in another tab — the embed will play full length.
      </p>
    </section>

    <section class="mt-14 md:mt-20">
      <MusicCarousel />
    </section>

    <section class="mx-auto mt-20 max-w-3xl text-center">
      <p class="font-mono text-xs uppercase tracking-[0.35em] text-sass-ink/45">listen everywhere</p>
      <div class="mt-5 flex flex-wrap items-center justify-center gap-2 font-mono text-xs uppercase tracking-widest">
        <a href="https://open.spotify.com/" target="_blank" rel="noopener" class="rounded-full border border-sass-ink/15 px-4 py-2 text-sass-ink/70 hover:border-sass-sauce hover:text-sass-sauce">Spotify</a>
        <a href="https://music.apple.com/" target="_blank" rel="noopener" class="rounded-full border border-sass-ink/15 px-4 py-2 text-sass-ink/70 hover:border-sass-sauce hover:text-sass-sauce">Apple Music</a>
        <a href="https://soundcloud.com/" target="_blank" rel="noopener" class="rounded-full border border-sass-ink/15 px-4 py-2 text-sass-ink/70 hover:border-sass-sauce hover:text-sass-sauce">SoundCloud</a>
        <a href="https://youtube.com/" target="_blank" rel="noopener" class="rounded-full border border-sass-ink/15 px-4 py-2 text-sass-ink/70 hover:border-sass-sauce hover:text-sass-sauce">YouTube</a>
      </div>
    </section>
  </main>

  <Footer />
</Base>
