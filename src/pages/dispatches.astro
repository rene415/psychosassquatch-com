---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base title="Dispatches — Psychosassquatch" description="3am thoughts, field notes, half-finished beats.">
  <Nav />

  <main class="px-5 pt-32 md:px-10">
    <section class="mx-auto max-w-3xl">
      <p class="font-mono text-xs uppercase tracking-[0.35em] text-sass-ink/50">05 — Dispatches</p>
      <h1 class="mt-3 font-display text-5xl md:text-7xl">Field notes from the woods.</h1>

      <ul class="mt-12 space-y-px overflow-hidden rounded-3xl border border-sass-ink/10 bg-sass-ink/5">
        {[
          { date: '2026·05·20', title: 'site is alive (barely)', body: 'first commit. it works. probably.' },
          { date: '2026·04·??', title: 'a beat that wouldn’t leave', body: 'looped a kick for six hours. neighbor knocked. did not stop.' },
          { date: '2025·12·17', title: 'on naming things', body: 'psycho + sass + sasquatch. it had to.' },
        ].map((p) => (
          <li class="bg-sass-bg p-6 md:p-8">
            <div class="flex items-baseline justify-between gap-4">
              <h2 class="font-display text-2xl">{p.title}</h2>
              <span class="font-mono text-xs text-sass-ink/40">{p.date}</span>
            </div>
            <p class="mt-2 text-sass-ink/70">{p.body}</p>
          </li>
        ))}
      </ul>
    </section>
  </main>

  <Footer />
</Base>
