  /* ── Logo-shaped mask: cover art + fracture layer clipped to shield silhouette ── */
  /* Uses the user-supplied PsychoSassquatch_outline.png after we removed its    */
  /* white background to make a real alpha mask.                                  */
  .logo-masked {
    -webkit-mask-image: url('/logo/PsychoSassquatch_outline_alpha.png');
    mask-image: url('/logo/PsychoSassquatch_outline_alpha.png');
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
  }

  /* ── Triangle field cells ─────────────────────────────────────────── */
  .viz-tri {
    position: absolute;
    transform-origin: center;
    will-change: transform, opacity;
    color: var(--accent, theme('colors.sass.sauce'));
    margin-left: calc(var(--w, 0) / -2);
    margin-top: calc(var(--w, 0) / -2);
    transform: translate(-50%, -50%);
    mix-blend-mode: screen;
    filter: drop-shadow(0 0 0.5vmin var(--accent-soft, rgba(255,93,42,0.4)));
  }
  .viz-tri svg { display: block; }

  /* When NOT playing, mute color to ink/ghost; when playing, accent */
  #player[data-playing="false"] .viz-tri,
  #player:not([data-playing]) .viz-tri { color: theme('colors.sass.ink' / 30%); }
  #player[data-playing="true"] .viz-tri { color: var(--accent, theme('colors.sass.sauce')); }

  /* ── Floating speckles (boosted: bigger, brighter, glow harder) ───── */
  .speckle {
    position: absolute;
    border-radius: 50%;
    background: var(--accent, theme('colors.sass.sauce'));
    box-shadow:
      0 0 var(--glow, 12px) var(--accent, theme('colors.sass.sauce')),
      0 0 calc(var(--glow, 12px) * 1.8) var(--accent-soft, rgba(255,93,42,0.5));
    opacity: 0;
    pointer-events: none;
    will-change: transform, opacity;
    mix-blend-mode: screen;
  }
  #player[data-playing="true"] .speckle {
    animation: speckle-drift var(--d, 12s) ease-in-out infinite;
  }
  @keyframes speckle-drift {
    0%   { opacity: 0;   transform: translate(0,           0)            scale(0.6); }
    15%  { opacity: 1;   transform: translate(calc(var(--dx,0)*0.25), calc(var(--dy,0)*0.25)) scale(1); }
    50%  { opacity: 0.95; transform: translate(var(--dx,0), var(--dy,0)) scale(1.1); }
    85%  { opacity: 1;   transform: translate(calc(var(--dx,0)*0.6), calc(var(--dy,0)*0.6)) scale(0.95); }
    100% { opacity: 0;   transform: translate(0,           0)            scale(0.6); }
  }

  /* ── Triangle drift (inner wrapper bounces slowly while playing) ──── */
  .viz-tri-drift {
    width: 100%;
    height: 100%;
    display: block;
    will-change: transform;
  }
  #player[data-playing="true"] .viz-tri-drift {
    animation: tri-drift var(--dur, 12s) ease-in-out infinite;
    animation-delay: var(--dly, 0s);
  }
  @keyframes tri-drift {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25%      { transform: translate(var(--dx, 0), calc(var(--dy, 0) * 0.5)) rotate(8deg); }
    50%      { transform: translate(calc(var(--dx, 0) * -0.6), var(--dy, 0)) rotate(-6deg); }
    75%      { transform: translate(calc(var(--dx, 0) * 0.4), calc(var(--dy, 0) * -0.6)) rotate(4deg); }
  }

  /* ── Main shield outline: stroke pulses ONLY when playing ────────────── */
  /* (the inline stroke-width=180 on the SVG path is the default at rest;     */
  /* the keyframes below override during playback in 7200-viewBox space)      */
  #player[data-playing="true"] #tri-main {
    stroke: var(--accent, theme('colors.sass.sauce'));
    animation: tri-pulse-play 1.2s ease-in-out infinite;
  }
  @keyframes tri-pulse-play {
