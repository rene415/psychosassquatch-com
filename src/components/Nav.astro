---
import { socials } from '../data/tracks';
const path = Astro.url.pathname;
const isHome = path === '/' || path === '';

const brandColors: Record<string, string> = {
  'Spotify':     '#1DB954',
  'Apple Music': '#FA243C',
  'SoundCloud':  '#FF5500',
  'YouTube':     '#FF0000',
  'Instagram':   '#E4405F',
  'Facebook':    '#1877F2',
};
---

<header class="fixed inset-x-0 top-0 z-30 px-5 py-4 md:px-10 md:py-6">
  <!-- 3-column layout: logo (left) | social icons (centered absolutely) | Merch (right) -->
  <div class="relative flex items-center justify-between gap-4">
    <div class="flex shrink-0 items-center gap-4">
      <a href="/" class="group inline-flex items-center gap-3" aria-label="Home">
        <img
          src="/logo/PsychoSassquatch.png"
          alt=""
          class="h-10 w-10 object-contain transition-transform duration-300 group-hover:rotate-[-8deg]"
          onerror="this.style.display='none'"
        />
        <span class="hidden font-display text-sm uppercase tracking-[0.25em] text-sass-ink/80 group-hover:text-sass-ink sm:inline">
          Psychosassquatch
        </span>
      </a>

      {!isHome && (
        <a
          id="now-playing-pill"
          href="/"
          class="hidden items-center gap-2 rounded-full border border-sass-ink/15 bg-sass-bg/50 px-3 py-1.5 font-mono text-[10px] uppercase tracking-widest text-sass-ink/75 backdrop-blur transition-colors hover:border-sass-sauce hover:text-sass-sauce md:inline-flex"
          aria-label="Now playing — go back to player"
        >
          <span class="now-playing-bars inline-flex h-3 items-end gap-[2px]" aria-hidden="true">
            <span class="block w-[2px] bg-sass-sauce"></span>
            <span class="block w-[2px] bg-sass-sauce"></span>
            <span class="block w-[2px] bg-sass-sauce"></span>
          </span>
          <span id="now-playing-title">— —</span>
        </a>
      )}
    </div>

    <!-- Social icons absolutely centered in the header row -->
    <ul class="absolute left-1/2 top-1/2 hidden -translate-x-1/2 -translate-y-1/2 items-center gap-1.5 sm:flex">
        {socials.map((s) => (
          <li>
            <a
              href={s.href}
              target="_blank"
              rel="noopener"
              aria-label={s.label}
              title={s.label}
              class="social-icon grid h-10 w-10 place-items-center rounded-full border border-sass-ink/10 bg-sass-bg/40 text-sass-ink/75 backdrop-blur transition-colors duration-200"
              style={`--brand: ${brandColors[s.label] ?? '#ff5d2a'};`}
              data-platform={s.label.toLowerCase().replace(/\s+/g, '-')}
            >
              {s.label === 'Spotify' && (
                <svg viewBox="0 0 24 24" class="h-[18px] w-[18px]" fill="currentColor" aria-hidden="true"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm4.6 14.3c-.2.3-.6.4-.9.2-2.5-1.5-5.7-1.9-9.4-1.0-.4.1-.7-.1-.8-.5-.1-.4.1-.7.5-.8 4.1-.9 7.7-.5 10.5 1.2.3.2.4.6.1.9zm1.2-2.7c-.3.3-.7.5-1.1.2-2.9-1.8-7.2-2.3-10.6-1.3-.4.1-.9-.1-1-.5-.1-.4.1-.9.5-1 3.9-1.2 8.7-.6 12 1.4.4.3.5.8.2 1.2zm.1-2.8c-3.4-2-9.1-2.2-12.4-1.2-.5.2-1.1-.1-1.2-.6-.2-.5.1-1.1.6-1.2 3.8-1.2 10.1-.9 14 1.4.5.3.6.9.4 1.4-.3.5-.9.6-1.4.3z"/></svg>
              )}
              {s.label === 'Apple Music' && (
                <svg viewBox="0 0 24 24" class="h-[18px] w-[18px]" fill="currentColor" aria-hidden="true"><path d="M17.7 3.2c-.4 0-.7.1-1 .2L9.4 5c-.6.1-1 .6-1 1.3v9.1c-.4-.2-.9-.3-1.4-.3-1.4 0-2.6 1-2.6 2.3s1.2 2.3 2.6 2.3 2.6-1 2.6-2.3V9.3l6.6-1.5v6.2c-.4-.2-.9-.3-1.4-.3-1.4 0-2.6 1-2.6 2.3s1.2 2.3 2.6 2.3 2.6-1 2.6-2.3V4.5c0-.7-.6-1.3-1.2-1.3z"/></svg>
              )}
              {s.label === 'SoundCloud' && (
                <svg viewBox="0 0 24 24" class="h-[18px] w-[18px]" fill="currentColor" aria-hidden="true"><path d="M2.5 13.5v3c0 .3.2.5.5.5s.5-.2.5-.5v-3c0-.3-.2-.5-.5-.5s-.5.2-.5.5zm2 0v3c0 .3.2.5.5.5s.5-.2.5-.5v-3c0-.3-.2-.5-.5-.5s-.5.2-.5.5zm2-1v4c0 .3.2.5.5.5s.5-.2.5-.5v-4c0-.3-.2-.5-.5-.5s-.5.2-.5.5zm2-2v6c0 .3.2.5.5.5s.5-.2.5-.5v-6c0-.3-.2-.5-.5-.5s-.5.2-.5.5zm2-1v7c0 .3.2.5.5.5s.5-.2.5-.5V9.5c0-.3-.2-.5-.5-.5s-.5.2-.5.5zm2-2v9c0 .3.2.5.5.5h7.5c1.7 0 3-1.3 3-3s-1.3-3-3-3c-.2 0-.4 0-.6.1-.4-2.3-2.5-4.1-4.9-4.1-1 0-1.9.3-2.7.8-.2-.1-.4-.2-.6-.2-.3 0-.5.2-.5.5z"/></svg>
              )}
              {s.label === 'YouTube' && (
                <svg viewBox="0 0 24 24" class="h-[18px] w-[18px]" fill="currentColor" aria-hidden="true"><path d="M21.6 7.2s-.2-1.4-.8-2c-.8-.8-1.6-.8-2-.9-2.8-.2-7-.2-7-.2s-4.2 0-7 .2c-.4.1-1.2.1-2 .9-.6.6-.8 2-.8 2S2 8.8 2 10.5v1.5C2 13.7 2.2 15.3 2.2 15.3s.2 1.4.8 2c.8.8 1.8.8 2.3.9 1.6.2 6.7.2 6.7.2s4.2 0 7-.2c.4-.1 1.2-.1 2-.9.6-.6.8-2 .8-2s.2-1.6.2-3.3v-1.5c0-1.7-.2-3.3-.2-3.3zM9.7 14V8.5l5.5 2.8L9.7 14z"/></svg>
              )}
              {s.label === 'Instagram' && (
                <svg viewBox="0 0 24 24" class="h-[18px] w-[18px]" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.9" fill="currentColor"/></svg>
              )}
              {s.label === 'Facebook' && (
                <svg viewBox="0 0 24 24" class="h-[18px] w-[18px]" fill="currentColor" aria-hidden="true"><path d="M13.5 22V13h3l.5-3.5h-3.5V7.3c0-1 .3-1.7 1.7-1.7H17V2.5c-.3 0-1.4-.1-2.6-.1-2.6 0-4.4 1.6-4.4 4.5v2.6H7V13h3v9z"/></svg>
              )}
            </a>
          </li>
        ))}
      </ul>

    <!-- Merch button on the right -->
    <nav aria-label="Primary" class="shrink-0">
      <a
        href="/merch"
          class:list={[
            'inline-flex h-10 items-center rounded-full border px-4 font-mono text-xs uppercase tracking-widest transition-colors duration-200',
            path.startsWith('/merch')
              ? 'border-sass-sauce bg-sass-sauce/15 text-sass-sauce'
              : 'border-sass-ink/15 text-sass-ink/80 hover:border-sass-ink/40 hover:text-sass-ink',
          ]}
        >
          Merch
        </a>
      </nav>
  </div>
</header>

<script>
  import { tracks } from '../data/tracks';

  function setupNowPlaying() {
    const pill = document.getElementById('now-playing-pill');
    if (!pill) return; // on home page, the pill isn't rendered

    const audio = document.getElementById('psy-audio') as HTMLAudioElement | null;
    const titleEl = document.getElementById('now-playing-title');
    if (!audio || !titleEl) return;

    function sync() {
      const src = audio!.src ? decodeURIComponent(audio!.src) : '';
      const idx = tracks.findIndex((t) => src.endsWith(t.audioSrc));
      if (idx >= 0) {
        titleEl!.textContent = tracks[idx].title;
        pill!.classList.remove('hidden');
        pill!.classList.add('md:inline-flex');
        pill!.setAttribute('data-playing', audio!.paused ? 'false' : 'true');
      } else {
        pill!.classList.add('hidden');
      }
    }

    sync();
    audio.addEventListener('play', sync);
    audio.addEventListener('pause', sync);
    audio.addEventListener('loadedmetadata', sync);
    audio.addEventListener('emptied', sync);
  }

  setupNowPlaying();
  document.addEventListener('astro:page-load', setupNowPlaying);
</script>

<style>
  .social-icon { transition: color 180ms ease, border-color 180ms ease, background-color 180ms ease; }
  .social-icon:hover { color: var(--brand); border-color: var(--brand); background-color: rgba(255,255,255,0.04); }

  /* Now-playing bar visualizer in the nav pill */
  .now-playing-bars span {
    display: block;
    height: 30%;
    transform-origin: bottom;
    animation: np-bar-bounce 0.9s ease-in-out infinite;
  }
  .now-playing-bars span:nth-child(2) { animation-delay: 0.15s; }
  .now-playing-bars span:nth-child(3) { animation-delay: 0.30s; }
  @keyframes np-bar-bounce {
    0%, 100% { height: 30%; }
    50%      { height: 100%; }
  }
  #now-playing-pill[data-playing="false"] .now-playing-bars span {
    animation-play-state: paused;
    height: 30%;
  }
</style>
