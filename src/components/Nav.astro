---
const path = Astro.url.pathname;
---

<header class="fixed inset-x-0 top-0 z-30 px-5 py-4 md:px-10 md:py-6">
  <div class="flex items-center justify-between gap-6">
    <a href="/" class="group inline-flex items-center gap-3" aria-label="Home">
      <img
        src="/logo/PsychoSassquatch.png"
        alt=""
        class="h-10 w-10 object-contain transition-transform duration-300 group-hover:rotate-[-8deg]"
        onerror="this.style.display='none'"
      />
      <span class="font-display text-sm uppercase tracking-[0.25em] text-sass-ink/80 group-hover:text-sass-ink">
        Psychosassquatch
      </span>
    </a>

    <nav aria-label="Primary">
      <ul class="flex items-center gap-1 font-mono text-xs uppercase tracking-widest">
        <li>
          <a
            href="/merch"
            class:list={[
              'rounded-full border px-3 py-1.5 transition-colors duration-200',
              path.startsWith('/merch')
                ? 'border-sass-sauce bg-sass-sauce/15 text-sass-sauce'
                : 'border-sass-ink/15 text-sass-ink/70 hover:border-sass-ink/40 hover:text-sass-ink',
            ]}
          >
            Merch
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>
